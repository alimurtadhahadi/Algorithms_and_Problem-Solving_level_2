#include <iostream>
#include <string>
using namespace std;
enum enNumberType { Prime = 1, NotPrime = 2 };
int ReadPositiveNumber(string Message)
{
	int Number;
	do {
		cout << Message;
		cin >> Number;
	} while (Number < 1);
	return Number;
}
enNumberType CheckNumber(int Number)
{
	if (Number < 2) {
		return enNumberType::NotPrime;
	}
	int Middle = Number / 2;
	for (int Counter = 2; Counter <= Middle; Counter++)
	{
		if (Number % Counter == 0) { return enNumberType::NotPrime; }
	}
	return enNumberType::Prime;
}
void PrintNumberType(int Number)
{
	switch (CheckNumber(Number))
	{
	case (enNumberType::NotPrime):
			cout << "Your Number is NOT Prime." << endl;
			break;
	case (enNumberType::Prime):
			cout << "Your Number is Prime." << endl;
			break;
	}
}
int main()
{
	PrintNumberType(ReadPositiveNumber("Please enter positve number :"));
	return 0;
}
