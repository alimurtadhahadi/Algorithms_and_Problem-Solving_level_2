#include <iostream>
#include <string>
using namespace std;
// Extracts and displays digits sequentially from right to left
long ReadPostiveNumber(string Message)
{
	long Number;
	do
	{
		cout << Message;
		cin >> Number;
	} while (Number <= 0);
	return Number;
}

void PrintDigitsInReverse(long number)
{
    long remainder = 0;

    while (number > 0)
    {
        // Capture the last digit (Least Significant Digit) using modulo 10
        remainder = number % 10;
        // Remove the processed last digit using integer division
        number = number / 10;
        // Render the captured digit to the console buffer
        cout << remainder << endl;
    }
}
int main()
{

    PrintDigitsInReverse(ReadPostiveNumber("Please enter a positive number :"));

    return 0;
}
