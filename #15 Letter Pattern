#include <iostream>
#include <string>
using namespace std;
// Function to read and validate a strict positive integer stream
int ReadPositiveNumber(string Message)
{
    int Number;
    do
    {
        cout << Message;
        cin >> Number;
    } while (Number <= 0); // Re-loops if entry violates positive boundaries
    return Number;
}
// Function managing nested loops to render the ascending ASCII character block
void PrintLetterPattern(int Number)
{
    cout << "\n";
    // Outer loop controls horizontal rows (increments sequentially from 1 up to Number)
    for (int i = 1; i <= Number; i++)
    {
        // Inner loop dictates the columns volume printed inside the active row frame
        for (int j = 1; j <= i; j++)
        {
            // Apply dynamic ASCII shifting offset based on the row state variable
            cout << char('A' + i - 1) << " ";
        }
        cout << endl; // Push the console carriage to a new line block
    }
}
int main()
{
    // Execute the nested layout pipeline matrix directly
    PrintLetterPattern(ReadPositiveNumber("Please enter positive number : "));
    return 0;
}
