#include <iostream>
#include <string>
#include <cmath>
using namespace std;

float ReadNumber()
{
    float Number = 0;

    cout << "please enter a Number : ";
    cin >> Number;

    return Number;
}

float MySqrt(float Number)
{
    return pow(Number, 0.5);
}

int main()
{
    float Number = ReadNumber();

    cout << "\nMy sqrt Result  : " << MySqrt(Number) << endl;
    cout << "C++ sqrt Result : " << sqrt(Number) << endl;

    return 0;
}
