#include <iostream>
#include <string>
#include <windows.h> 
using namespace std;
// Clears the screen cleanly using ANSI sequences
void ClearScreen()
{
    cout << "\033[H\033[J";
}
// Adjusts margin spacing for row index 10
string ColumSperator1(int i)
{
    if (i < 10)
        return "    |";
    else
        return "   |";
}
// Handles dynamic margin padding for 3-digit final numbers
string ColumSperator2(int result)
{
    if (result >= 100)
        return "   |";
    else
        return "    |";
}
// Custom 7-line header layout matching Ali's exact style
void PrintTableHeader()
{
    cout << "\n\n\t\t\t Multiplication Table From 1 to 10\n\n";
    cout << "\n|-----|" << string(79, '-') << "|";
    cout << "\n|  *  |";
    for (int i = 1; i <= 10; i++)
    {
        cout << "\t" << i;
    }
    cout << "    |\n|-----|" << string(79, '-') << "|" << "\n";
}
// Main logic core function for rendering the matrix grid
void PrintMultiplicationTable()
{
    PrintTableHeader();
    int j = 1;
    int i = 1;
    for (i = 1; i <= 10; i++)
    {
        cout << "|" << i << ColumSperator1(i);
        for (j = 1; j <= 10; j++)
        {
            cout << "\t" << i * j;
        }
        cout <<ColumSperator2(i * 10) << endl;
    }
    cout << "|-----|" << string(79, '-') << "|" << "\n";
}
int main()
{
    PrintMultiplicationTable();
    return 0;
}
