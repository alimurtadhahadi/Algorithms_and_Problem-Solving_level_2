#include <iostream>
#include <string>
using namespace std;
// Stream driver to capture complete text structures
string ReadText()
{
    string Text;
    cout << "Please enter Text : ";
    getline(cin, Text);
    return Text;
}
// Cipher core utilizing strict boundary checks (< length)
string EncryptText(string Text, short EncryptionKey)
{
    for (int i = 0; i < Text.length(); i++)
    {
        Text[i] = char(Text[i] + EncryptionKey);
    }
    return Text;
}
// Decryption core mirroring the baseline constraint limits
string DecryptText(string Text, short EncryptionKey)
{
    for (int i = 0; i < Text.length(); i++)
    {
        Text[i] = char(Text[i] - EncryptionKey);
    }
    return Text;
}
int main()
{
    const short EncryptionKey = 2;
    string TextAfterEncryption, TextAfterDecryption;
    string Text = ReadText();
    // Process the data cascades sequentially via the memory pipeline
    TextAfterEncryption = EncryptText(Text, EncryptionKey);
    TextAfterDecryption = DecryptText(TextAfterEncryption, EncryptionKey);
    // Render security metrics onto the output console frame
    cout << "\nText Before Encryption : " << Text;
    cout << "\nText After Encryption  : " << TextAfterEncryption;
    cout << "\nText After Decryption  : " << TextAfterDecryption << "\n";
    return 0;
}
