#include <iostream>
#include <string>
using namespace std;
// Strict enumeration mapping for perfect calculation flags
enum enNumberType
{
    perfect = 1,
    Notperfect = 2
};
// Captures and validates strict positive integer stream boundaries
long long ReadPositiveNumber(string message)
{
    long long number = 0;
    do
    {
        cout << message;
        cin >> number;
    } while (number < 1);
    return number;
}
// Optimized algorithmic core utilizing mid-boundary loops
enNumberType isPerfectNumber(long long number)
{
    long long sum = 0;
    long long middle = number / 2;
    // Loop optimized to execute strictly up to the mid-point vector
    for (long long i = 1; i <= middle; i++)
    {
        if (number % i == 0)
        {
            sum += i;
        }
    }
    if (number == sum)
    {
        return enNumberType::perfect;
    }
    else
    {
        return enNumberType::Notperfect;
    }
}
// Iterates across range slots and renders verified perfect values
void PrintResults(long long number)
{
    cout << "\nOptimized Perfect Numbers from 6 to " << number << " are:\n";

    // Boundary adjusted to '<=' to ensure upper limit inclusion
    for (long long i = 6; i <= number; i++)
    {
        if (isPerfectNumber(i) == enNumberType::perfect)
        {
            cout << i << "\t";
        }
    }

    cout << "\n";
}
int main()
{
    PrintResults(ReadPositiveNumber("Please enter positive number: "));
    return 0;
}
