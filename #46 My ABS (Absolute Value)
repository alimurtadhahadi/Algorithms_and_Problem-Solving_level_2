#include <iostream>
#include <cmath>

using namespace std;

float MyABS(float Number)
{
    if (Number < 0)
    {
        return Number * -1;
    }

    return Number;
}

float ReadNumber()
{
    float Number;

    cout << "Please enter a number : ";
    cin >> Number;

    return Number;
}

int main()
{
    float Number = ReadNumber();

    cout << "\nMy abs Result  : " << MyABS(Number) << endl;
    cout << "C++ abs Result : " << abs(Number) << endl;

    return 0;
}
