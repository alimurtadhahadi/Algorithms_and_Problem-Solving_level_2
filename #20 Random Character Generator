#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

// Core mathematical function to isolate and scale pseudo-random outputs
int RandomNumber(int From, int To)
{
    int randNum = rand() % (To - From + 1) + From;
    return randNum;
}

// Strongly-typed enumeration mapping character modes to scalar data bounds
enum enCharType {
    SmallLetter = 1,
    CapitalLetter = 2,
    SpecialCharacter = 3,
    Digit = 4
};

// Evaluates the enumeration state to fetch and type-cast the target ASCII symbol
char GetRandomCharacter(enCharType CharType)
{
    switch (CharType)
    {
    case enCharType::SmallLetter:
        return char(RandomNumber(97, 122)); // Bounded [a-z] ASCII segment

    case enCharType::CapitalLetter:
        return char(RandomNumber(65, 90));  // Bounded [A-Z] ASCII segment

    case enCharType::SpecialCharacter:
        return char(RandomNumber(33, 47));  // Bounded [!, /] punctuation segment

    case enCharType::Digit:
        return char(RandomNumber(48, 57));  // Bounded [0-9] numerical symbol segment
    }

    return '\0'; // Sentinel null token for safe fallback invariant execution
}

int main()
{
    // Seed the hardware PRNG engine with the dynamic system time metrics
    srand((unsigned)time(NULL));

    // Output the generated character matrix directly onto the terminal pipeline
    cout << GetRandomCharacter(enCharType::SmallLetter) << endl;
    cout << GetRandomCharacter(enCharType::CapitalLetter) << endl;
    cout << GetRandomCharacter(enCharType::SpecialCharacter) << endl;
    cout << GetRandomCharacter(enCharType::Digit) << endl;

    return 0;
}
