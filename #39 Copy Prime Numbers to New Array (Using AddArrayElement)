#include <iostream>
#include <cstdlib>
#include <ctime>
#include <string>

using namespace std;

enum enNumberType
{
    Prime = 1,
    NotPrime = 2
};

enNumberType CheckNumber(int number)
{
    if (number < 2)
    {
        return enNumberType::NotPrime;
    }

    int middle = number / 2;

    for (int counter = 2; counter <= middle; counter++)
    {
        if (number % counter == 0)
        {
            return enNumberType::NotPrime;
        }
    }

    return enNumberType::Prime;
}

int RandomNumber(int From, int To)
{
    int randNum = rand() % (To - From + 1) + From;
    return randNum;
}

int ReadArrayLength(string Message, int MaxSize)
{
    int Number = 0;

    do
    {
        cout << Message;
        cin >> Number;
    } while (Number <= 0 || Number > MaxSize);

    return Number;
}

void AddArrayElement(int Number, int Arr[100], int& ArrLength)
{
    ArrLength++;
    Arr[ArrLength - 1] = Number;
}

void PrintArray(int Arr[100], int ArrLength)
{
    for (int i = 0; i < ArrLength; i++)
    {
        cout << Arr[i] << " ";
    }
    cout << endl;
}

void FillArrayWithRandomNumbers(int Arr[100], int& ArrLength)
{
    ArrLength = ReadArrayLength("Enter number of elements (1 to 100): ", 100);

    for (int i = 0; i < ArrLength; i++)
    {
        Arr[i] = RandomNumber(1, 100);
    }
}

void CopyPrimeNumbersUsingAddArrayElement(int ArrSource[100], int ArrDestination[100], int ArrLength, int& ArrDestinationLength)
{
    for (int i = 0; i < ArrLength; i++)
    {
        if (CheckNumber(ArrSource[i]) == enNumberType::Prime)
        {
            AddArrayElement(ArrSource[i], ArrDestination, ArrDestinationLength);
        }
    }
}

int main()
{
    srand((unsigned)time(NULL));

    int Arr1[100];
    int ArrLength1 = 0;
    FillArrayWithRandomNumbers(Arr1, ArrLength1);

    int Arr2[100];
    int Arr2Length = 0;

    CopyPrimeNumbersUsingAddArrayElement(Arr1, Arr2, ArrLength1, Arr2Length);

    cout << "\nArray 1 elements:\n";
    PrintArray(Arr1, ArrLength1);

    cout << "\nArray 2 Prime numbers:\n";
    PrintArray(Arr2, Arr2Length);

    return 0;
}
