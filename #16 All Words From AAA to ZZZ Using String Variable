#include <iostream>
#include <string>
using namespace std;
// Function generating permutations strictly bounded inside a dynamic string object
void PrintLetterPattern()
{
    cout << "\n";
    int seq = 0;       // Sequence counter for tracking total permutations
    string word = "";  // Dynamic string variable explicitly mandated by the professor
    // Outer Loop: Controls the 1st positional character slot
    for (int i = 'A'; i <= 'Z'; i++)
    {
        // Middle Loop: Controls the 2nd positional character slot
        for (int j = 'A'; j <= 'Z'; j++)
        {
            // Inner Loop: Controls the 3rd positional character slot
            for (int k = 'A'; k <= 'Z'; k++)
            {
                seq++; // Increment unique iteration sequence key
                // Constructing the word inside the variable as requested by the professor
                word = ""; // Step A: Clear the variable container cache from older frames
                word.append(1, char(i)); // Step B: Append the active row character literal
                word.append(1, char(j)); // Step C: Append the middle frame character literal
                word.append(1, char(k)); // Step D: Append the rapid-cycling inner literal
                // Step E: Output the fully compiled variable data onto the terminal
                cout << seq << " " << word << "\n";
            }
        }
        cout << "\n"; // Inject structural spacing block per major character transition
    }
}
int main()
{
    // Fire up the dynamic string concatenation permutation engine
    PrintLetterPattern();
    return 0;
}
