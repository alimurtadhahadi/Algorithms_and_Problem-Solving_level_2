#include <iostream>
#include <string>
#include <cmath>

using namespace std;

float ReadNumber()
{
    float num = 0;

    cout << "please enter a Number : ";
    cin >> num;

    return num;
}

int MyFloor(float Number)
{
    int IntPart = int(Number);

    if (Number >= 0 || Number == IntPart)
    {
        return IntPart;
    }
    else
    {
        return IntPart - 1;
    }
}

int main()
{
    float Number = ReadNumber();

    cout << "\nMy floor Result  : " << MyFloor(Number) << endl;
    cout << "C++ floor Result : " << floor(Number) << endl;

    return 0;
}
