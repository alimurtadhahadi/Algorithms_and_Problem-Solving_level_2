#include <iostream>
#include <cstdlib>
#include <ctime>
#include <string>
using namespace std;
// Core mathematical function to isolate and scale pseudo-random outputs
int RandomNumber(int From, int To)
{
    int randNum = rand() % (To - From + 1) + From;
    return randNum;
}
// Strongly-typed enumeration mapping character modes to scalar data bounds
enum enCharType {
    SmallLetter = 1,
    CapitalLetter = 2,
    SpecialCharacter = 3,
    Digit = 4
};
// Evaluates the enumeration state to fetch and type-cast the target ASCII symbol
char GetRandomCharacter(enCharType CharType)
{
    switch (CharType)
    {
    case enCharType::SmallLetter:
        return char(RandomNumber(97, 122));

    case enCharType::CapitalLetter:
        return char(RandomNumber(65, 90));

    case enCharType::SpecialCharacter:
        return char(RandomNumber(33, 47));

    case enCharType::Digit:
        return char(RandomNumber(48, 57));
    }

    return '\0';
}
// Stream driver to read and validate a strict positive integer input
int ReadPositiveNumber(string Message)
{
    int Number = 0;

    do
    {
        cout << Message;
        cin >> Number;
    } while (Number <= 0);

    return Number;
}
// Accumulates individual random character tokens into a dynamic string block
string GenerateWord(enCharType CharType, short Length)
{
    string word = ""; // Explicit initialization of local string container

    for (int i = 1; i <= Length; i++)
    {
        word = word + GetRandomCharacter(CharType);
    }

    return word;
}
// Overloaded Function (Pass A): Compiles 5 distinct blocks into a single key string
string GenerateKey()
{
    string Key = "";

    // Concatenate 5-character capital words segmented cleanly by hyphen tokens
    Key = GenerateWord(enCharType::CapitalLetter, 5) + "-" +
        GenerateWord(enCharType::CapitalLetter, 5) + "-" +
        GenerateWord(enCharType::CapitalLetter, 5) + "-" +
        GenerateWord(enCharType::CapitalLetter, 5) + "-" +
        GenerateWord(enCharType::CapitalLetter, 5);

    return Key;
}
// Overloaded Function (Pass B): Drives the execution loop to print multiple keys
void GenerateKey(unsigned short NumberOfKeys)
{
    cout << "\n";

    for (int i = 1; i <= NumberOfKeys; i++)
    {
        cout << "Key [" << i << "] : " << GenerateKey() << "\n";
    }
}
int main()
{
    // Seed the hardware PRNG engine with the dynamic system time metrics
    srand((unsigned)time(NULL));

    // Fire the overloaded pipeline architecture directly
    GenerateKey(ReadPositiveNumber("Please enter number of Keys : "));

    return 0;
}
