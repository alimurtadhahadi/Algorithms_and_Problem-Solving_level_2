#include <iostream>
#include <string>
#include <windows.h>
using namespace std;

// Captures input password stream and purges residual memory carriage returns
string ReadPassword()
{
    string Password;
    cout << "Please enter a 3-Letter Password (all capital or all small) : ";
    cin >> Password;
    // Purge the input stream buffer to prevent residual '\n' from skipping subsequent breaks
    cin.ignore(10000, '\n');
    return Password;
}
// Upper-case matrix crack driver processing slots across [A-Z]
bool GuessPasswordIfCapital(string OriginalPassword)
{
    cout << "\n[Ali_Dev Security] : Deploying Uppercase Space Brute-Force...\n\n";
    int seq = 0;
    string word = "";
    for (int i = 'A'; i <= 'Z'; i++)
    {
        for (int j = 'A'; j <= 'Z'; j++)
        {
            for (int k = 'A'; k <= 'Z'; k++)
            {
                seq++;
                word = ""; // Flush buffer
                word.append(1, char(i));
                word.append(1, char(j));
                word.append(1, char(k));
                cout << "Trial [" << seq << "] : " << word << "\n";
                // Integrity check: match verified
                if (OriginalPassword == word){
                    cout << "\n🎯 SUCCESS! Password is confirmed as: " << word << "\n";
                    cout << "🔑 Cracked after " << seq << " Total Trial(s).\n";
                    return true;
                }
            }
        }
        cout << "\n";
    }
    return false;
}
// Lower-case matrix crack driver processing slots across [a-z] starting tracking bounds from 17,576
bool GuessPasswordIfSmall(string OriginalPassword)
{
    cout << "\n[Ali_Dev Security] : Shift detected. Deploying Lowercase Space Brute-Force...\n\n";
    int seq = 17576; // Accumulate trials count directly from legacy uppercase space boundaries
    string word = "";
    for (int i = 'a'; i <= 'z'; i++)
    {
        for (int j = 'a'; j <= 'z'; j++)
        {
            for (int k = 'a'; k <= 'z'; k++)
            {
                seq++;
                word = ""; // Flush buffer
                word.append(1, char(i));
                word.append(1, char(j));
                word.append(1, char(k));
                cout << "Trial [" << seq << "] : " << word << "\n";
                // Integrity check: match verified
                if (OriginalPassword == word)
                {
                    cout << "\n🎯 SUCCESS! Password is confirmed as: " << word << "\n";
                    cout << "🔑 Cracked after " << seq << " Total Trial(s).\n";
                    return true;
                }
            }
        }
        cout << "\n";
    }
    return false;
}
// Centralized execution engine directing pipeline flow based on character space requirements
void StartPasswordCrackingEngine()
{
    string OriginalPassword = ReadPassword();
    // Attempt execution pass A (Uppercase domain)
    if (!GuessPasswordIfCapital(OriginalPassword))
    {
        cout << "\n⚠️ Target not found in Uppercase domain. Press ENTER to cascade to Lowercase space...";
        cin.get(); // Synchronous hold now pauses perfectly due to buffer purge
        // Attempt execution pass B (Lowercase domain)
        if (!GuessPasswordIfSmall(OriginalPassword))
        {
            cout << "\n❌ Execution Fault: Your password did not meet the structural requirements.\n";
            cout << "Idiot!!!!\n";
        }
    }
}
int main()
{
    // Fire up the rebranded cyber security execution engine
    StartPasswordCrackingEngine();
    return 0;
}
