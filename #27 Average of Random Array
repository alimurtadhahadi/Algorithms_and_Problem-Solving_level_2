#include <iostream>
#include <cstdlib>
#include <ctime>
#include <string>
using namespace std;

// Core mathematical function to isolate and scale pseudo-random outputs
int RandomNumber(int From, int To)
{
    int randNum = rand() % (To - From + 1) + From;
    return randNum;
}

// Secure stream driver to capture array sizes strictly bounded within limits
int ReadArrayLength(string Message, int MaxSize)
{
    int Number = 0;
    do
    {
        cout << Message;
        cin >> Number;
    } while (Number <= 0 || Number > MaxSize);

    return Number;
}

// Secure system function driven by validated size properties
void FillArrayWithRandomNumbers(int Arr[100], int& ArrLength)
{
    ArrLength = ReadArrayLength("Enter number of elements (1 to 100): ", 100);

    for (int i = 0; i < ArrLength; i++)
    {
        Arr[i] = RandomNumber(1, 100);
    }
}

// Safe read-only array stream printing 
void PrintArray(int Arr[100], int ArrLength)
{
    for (int i = 0; i < ArrLength; i++)
    {
        cout << Arr[i] << " ";
    }
    cout << endl;
}

// Scans the array structure linearly to capture the absolute maximum value
int MaxNumberInArray(int Arr[100], int ArrLength)
{
    int Max = 0;

    for (int i = 0; i < ArrLength; i++)
    {
        if (Arr[i] > Max)
        {
            Max = Arr[i];
        }
    }

    return Max;
}

// Scans the array structure linearly to capture the absolute minimum value
int MinNumberInArray(int Arr[100], int ArrLength)
{
    int Min = Arr[0];

    for (int i = 1; i < ArrLength; i++)
    {
        if (Arr[i] < Min)
        {
            Min = Arr[i];
        }
    }

    return Min;
}

// Linearly traverses the matrix registers to compile a cumulative scalar total
int SumArray(int Arr[100], int ArrLength)
{
    int sum = 0;
    for (int i = 0; i < ArrLength; i++)
    {
        sum += Arr[i];
    }

    return sum;
}

// Pulls the cumulative register metrics to resolve the floating-point average
float ArrayAverage(int sumArray, int ArrLength)
{
    // Inject compile-time explicit float promotion to capture fraction bounds
    return (float)sumArray / ArrLength;
}

int main()
{
    // Seed the hardware PRNG engine with the dynamic system time metrics
    srand((unsigned)time(NULL));

    int Arr[100];
    int ArrLength;

    // Fire secure dynamic data allocation pipelines
    FillArrayWithRandomNumbers(Arr, ArrLength);

    cout << "\nArray Elements: ";
    PrintArray(Arr, ArrLength);

    // Capture and cache data values into active stack registers
    int sumArray = SumArray(Arr, ArrLength);
    float arrayAverage = ArrayAverage(sumArray, ArrLength);

    // Output unified telemetry metrics directly onto the terminal pipeline
    cout << "\nMax Number is : " << MaxNumberInArray(Arr, ArrLength);
    cout << "\nMin Number is : " << MinNumberInArray(Arr, ArrLength) << endl;
    cout << "\nSum of all numbers is : " << sumArray;
    cout << "\nAverage of all numbers is : " << arrayAverage << endl;

    return 0;
}
